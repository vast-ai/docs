#!/bin/sh
# Auto-rebuild api-reference/openapi.yaml when any source YAML is staged.
# Enable with:  git config core.hooksPath .githooks
set -eu

staged_yaml=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^api-reference/openapi/yaml/.*\.yaml$' || true)
if [ -z "$staged_yaml" ]; then
    exit 0
fi

echo "pre-commit: source YAML changed, rebuilding api-reference/openapi.yaml..."
python3 api-reference/openapi/build.py >/dev/null

if ! git diff --quiet api-reference/openapi.yaml; then
    git add api-reference/openapi.yaml
    echo "pre-commit: staged regenerated api-reference/openapi.yaml"
fi
